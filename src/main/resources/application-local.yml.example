# ──────────────────────────────────────────────────────────────────────────
# 本地开发 profile 模板（cp 为 application-local.yml 后填入真实值）
#
# ⚠️  application-local.yml 已在 .gitignore 中，**绝不要**提交真实 yml
# ⚠️  所有 hex 值（私钥、地址）必须用双引号包裹，否则 YAML 1.1 解析成整数
# ──────────────────────────────────────────────────────────────────────────
spring:
  datasource:
    url: jdbc:mysql://localhost:3307/web2health_oracle?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
    username: root
    password: <YOUR_DB_PASSWORD>
    driver-class-name: com.mysql.cj.jdbc.Driver

  flyway:
    repair-on-migrate: true

# ── GitHub PAT（提升 GitHub API 限频 60→5000/h）──────────────────────────
github:
  token: <YOUR_GITHUB_PAT>

# ── CoinGecko Demo Key（https://www.coingecko.com/en/api/pricing）────────
coingecko:
  demo-key: <YOUR_COINGECKO_DEMO_KEY>

# ── HTTP 代理（CN 大陆开发可能需要）─────────────────────────────────────
# 不需要代理则注释整段
proxy:
  url: http://127.0.0.1:7890

# ── Admin 接口 token（生产环境必须改成强随机值）────────────────────────
admin:
  api-token: <YOUR_ADMIN_TOKEN>

# ── x402 计费 ─────────────────────────────────────────────────────────
x402:
  enabled: true
  pay-to: "0x0000000000000000000000000000000000000001"  # 占位，演示用

# ── 本地端口 ─────────────────────────────────────────────────────────
server:
  port: 8086

# ── T2 签名私钥 ────────────────────────────────────────────────────────
# ⚠️ 必须加双引号！否则 YAML 把 0x... 当 hex 整数
# ⚠️ 生产部署改用环境变量或 Turnkey MPC
# 测试用值（公开的 web3.js 示例私钥，仅本地）：
#   0x4c0883a69102937d6231471b5dbb6204fe5129617082792ae468d01a3f362318
#   → 公钥地址 0x2c7536e3605d9c16a7a3d7b1898e529396a65c23
t2:
  signer-private-key: "<YOUR_T2_SIGNER_PRIVATE_KEY>"

# ── T3 链上推送（部署 HealthOracle.sol 后填入）────────────────────────
# 部署步骤见 docs/T3-DEPLOYMENT-GUIDE.md
t3:
  enabled: false
  health-oracle-address: "<DEPLOYED_CONTRACT_ADDRESS>"
  publisher-private-key: "<PUBLISHER_PRIVATE_KEY>"

# ── 日志 ───────────────────────────────────────────────────────────────
logging:
  level:
    com.web2health.oracle: DEBUG
    org.springframework.cache: DEBUG
